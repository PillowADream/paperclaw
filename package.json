{
  "name": "paperclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "gemini": "npm run build && node dist/index.js",
    "archive:list": "npm run build && node dist/index.js archive:list",
    "archive:thread": "npm run build && node dist/index.js archive:thread",
    "archive:search": "npm run build && node dist/index.js archive:search",
    "archive:reembed": "npm run build && node dist/index.js archive:reembed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@langchain/core": "^1.0.6",
    "@langchain/openai": "^1.0.6",
    "browser-use-typescript": "^1.0.10",
    "dotenv": "^16.4.7",
    "langchain": "^1.0.6",
    "pg": "^8.20.0",
    "playwright": "^1.53.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
